<div class="container mx-auto max-w-4xl">
  <h1 class="text-3xl font-bold mt-6 text-center"><%= t(".title") %></h1>
  <p class="mt-2 text-center text-xl text-gray-700"><%= t(".description", name: SellRepo.store_name) %></p>

  <div class="mt-6 flex flex-col rounded-lg divide-y divide-gray-200 bg-white border border-gray-200">
    <%= render @announcements %>

    <% if @announcements.empty? %>
      <div class="p-4 lg:p-10"><%= t(".empty_placeholder") %></div>
    <% end %>
  </div>

  <% if @pagy.last > 1 %>
    <div class="text-center mt-8">
      <%== @pagy.series_nav %>
    </div>
  <% end %>
</div>
