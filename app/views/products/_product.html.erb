<div class="text-center group">
  <%= link_to product, class: "no-underline hover:underline" do %>
    <%= image_tag(product.featured_image, class: "mt-0 mb-2 rounded-md group-hover:opacity-80") if product.featured_image.attached? %>
    <div class="mt-6">
      <h3 class="mt-1 font-semibold text-gray-900">
        <%= product.name %>
      </h3>
      <div class="mt-1 text-gray-900"><%= number_to_currency product.amount_in_cents / 100.0 %></div>
    </div>
  <% end %>
</div>
